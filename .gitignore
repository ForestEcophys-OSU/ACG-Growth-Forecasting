# Environment files
.env

# --- IDEs and Editors ---
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.code-workspace  

# --- Linux ---
*~
.nfs*

# Output files from R CMD build
/*.tar.gz

# Output files from R CMD check
/*.Rcheck/

# Python files
Pysrc/
__pycache__/
*.pyc

# R files
*-Ex.R
.Rapp.history
.RData
.RDataTmp
.Renviron
.Rhistory
.Rproj.user/
rsconnect/
.Ruserdata

# R vignettes
vignettes/*.html
vignettes/*.pdf

# Virtual environment
.venv/
venv/

# OAuth2 token, see https://github.com/hadley/httr/releases/tag/v0.3
.httr-oauth

# knitr and R markdown default cache directories
*_cache/
/cache/

# Temporary files created by R markdown
*.utf8.md
*.knit.md

# User-added directories
data/*
output/*

# translation temp files
po/*~

# --- macOS ---
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# --- Windows ---
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/



  



